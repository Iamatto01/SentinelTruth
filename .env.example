# SentinelTruth Environment Variables
# All APIs are FREE — no credit card required

# Groq API — Get at https://console.groq.com → API Keys
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
# Optional: additional comma-separated keys appended after the slots above
GROQ_API_KEYS=
GROQ_MAX_PER_MINUTE=25
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_ANALYZE_MAX_TOKENS=400
GROQ_TRANSLATE_MAX_TOKENS=800

# HuggingFace — Get at https://huggingface.co → Settings → Access Tokens
HF_API_TOKEN=

# Ollama (optional local/self-hosted model)
# Enable only if an Ollama server is reachable by this app.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=45000

# Facebook Graph API token (required for Facebook post collection)
FACEBOOK_ACCESS_TOKEN=

# Comma-separated Facebook page IDs/usernames to pull public posts from
FACEBOOK_PAGE_IDS=bernamaofficial,malaysiakini,TheStarOnline,FMTNews

# Server
PORT=3000
NODE_ENV=production

# Turso (optional libSQL backend setup/migration)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Firebase Storage (optional, needed for social feed image upload)
# These values are safe to expose to frontend clients.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=

# Social mode
# true  = server auto-posts all topics into social feed (interactive via reaction/comment/share only)
# false = allow manual user post creation
SOCIAL_SERVER_POSTS_ONLY=true

# Agent Settings
AI_PROVIDER_MODE=groq-only
AGENT_AUTO_START=false
SEARCH_INTERVAL_MS=60000
ANALYZE_INTERVAL_MS=8000
ANALYZE_BATCH_SIZE=2
SEARCH_QUEUE_BATCH_SIZE=3
SEARCH_FETCH_TARGET=350
REVERIFY_ENABLED=true
REVERIFY_INTERVAL_MS=45000
REVERIFY_BATCH_SIZE=1

# Search date window for Google News RSS queries (empty end date = today)
SEARCH_START_DATE=2019-01-01
SEARCH_END_DATE=

# Real-data enforcement
STRICT_REAL_MODE=true
MALAYSIA_POLITICS_ONLY=false
VERIFICATION_MIN_SCORE=65
ALLOW_SIMULATED_DATA=false

# Data file paths / safety
TOPICS_FILE_PATH=server/data/topics.json
AGENT_LOG_FILE_PATH=server/data/agent-log.json
SEED_ON_EMPTY=false
ENABLE_AGENT_RESET=false

# Bulk collector tuning
COLLECTOR_DEFAULT_TARGET=2500
COLLECTOR_TIMEOUT_MS=15000
